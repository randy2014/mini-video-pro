<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <!-- 头部 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="迷你视频"
            android:textSize="30sp"
            android:textColor="#D4AF37"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_marginTop="72dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIP 视频权益"
            android:textSize="14sp"
            android:textColor="#CFC3E6"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="36dp" />

        <!-- 账号 -->
        <EditText
            android:id="@+id/et_account"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="输入账号 (手机号)"
            android:textColor="#F0E8FF"
            android:textColorHint="#A99BBD"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="phone"
            android:singleLine="true"
            android:textSize="16sp"
            android:layout_marginBottom="14dp" />

        <!-- 密码 -->
        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="输入密码"
            android:textColor="#F0E8FF"
            android:textColorHint="#A99BBD"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:textSize="16sp"
            android:layout_marginBottom="14dp" />

        <!-- 权益码（必填） -->
        <EditText
            android:id="@+id/et_entitlement_code"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="输入权益码 (8位数字，必填)"
            android:textColor="#F0E8FF"
            android:textColorHint="#A99BBD"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="number"
            android:singleLine="true"
            android:maxLength="8"
            android:textSize="16sp"
            android:layout_marginBottom="14dp" />

        <!-- 图形验证码 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/et_captcha"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="图形验证码"
                android:textColor="#F0E8FF"
                android:textColorHint="#A99BBD"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:singleLine="true"
                android:maxLength="6"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iv_captcha"
                android:layout_width="110dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:scaleType="centerCrop"
                android:contentDescription="验证码"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_input" />
        </LinearLayout>

        <!-- 登录按钮 -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="登录 / 注册"
            android:textColor="#1A0A2E"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_button_gold"
            android:minHeight="56dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="18dp" />

        <!-- 提示 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="账号不存在时将自动注册"
            android:textSize="12sp"
            android:textColor="#A99BBD" />

        <!-- 版本号 -->
        <TextView
            android:id="@+id/tv_login_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#817392"
            android:layout_marginTop="24dp"
            android:text="v1.0" />

    </LinearLayout>
</ScrollView>
