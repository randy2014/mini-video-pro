<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ====== 首页 ====== -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <ScrollView
            android:id="@+id/home_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_home_gradient">

                <!-- 顶部 Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="56dp"
                    android:paddingBottom="32dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="视频权益"
                        android:textSize="26sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <!-- 金色装饰线 -->
                    <View
                        android:layout_width="32dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="#D4AF37" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="精选平台 · 随心观看"
                        android:textSize="12sp"
                        android:textColor="#B8A9D4"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- 统计卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:layout_marginTop="-4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card">

                        <TextView
                            android:id="@+id/stat_platforms"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="20sp"
                            android:textColor="#7C5CBF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="视频平台"
                            android:textSize="11sp"
                            android:textColor="#9999A8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card">

                        <TextView
                            android:id="@+id/stat_music"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="20sp"
                            android:textColor="#E07B5A"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="音乐平台"
                            android:textSize="11sp"
                            android:textColor="#9999A8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card">

                        <TextView
                            android:id="@+id/stat_tv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="20sp"
                            android:textColor="#D4AF37"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="电视直播"
                            android:textSize="11sp"
                            android:textColor="#9999A8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 平台容器 (纯动态填充) -->
                <LinearLayout
                    android:id="@+id/platform_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp" />

                <!-- 版本号 -->
                <TextView
                    android:id="@+id/version_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="v1.2"
                    android:textSize="11sp"
                    android:textColor="#555566"
                    android:gravity="center"
                    android:paddingBottom="48dp" />
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- 加载遮罩 -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#1A0A2E"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="#7C5CBF" />

        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textSize="14sp"
            android:textColor="#B8A9D4"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- ====== 浏览器 ====== -->
    <LinearLayout
        android:id="@+id/browser_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#1A0A2E">

        <!-- 浏览器顶栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#CC1E1035"
            android:paddingStart="8dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/back_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/title_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp" />
        </LinearLayout>

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#D4AF37"
            android:progressBackgroundTint="#33FFFFFF" />

        <WebView
            android:id="@+id/web_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

</FrameLayout>
